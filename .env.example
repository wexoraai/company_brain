# Database Configurations
# Use postgresql+asyncpg for SQLAlchemy async operations
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5432/company_brain

# AI API Configurations
# Provide your Gemini API key (or Claude/OpenAI if preferred)
GEMINI_API_KEY=your_gemini_api_key_here

# Application Settings
PORT=8000
SECRET_KEY=some_super_secret_signing_key_for_session_management
UPLOAD_DIR=./uploads

# Integration API Mock Keys (Optional - default to mocks if empty)
ZOHO_CRM_API_KEY=mock_zoho_crm_key
ZOHO_BOOKS_API_KEY=mock_zoho_books_key
RETELL_API_KEY=mock_retell_key

# Supabase Configurations (Optional - defaults to local database/storage if empty)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here
SUPABASE_BUCKET=company-brain-docs

